    "plugins/consensus/scripts/loop-args.mjs",
    "plugins/consensus/scripts/consensus-cli-helpers.mjs",
    "plugins/consensus/skills/create/scripts/consensus-cli-helpers.mjs",
    "plugins/consensus/skills/decide/scripts/consensus-cli-helpers.mjs",
