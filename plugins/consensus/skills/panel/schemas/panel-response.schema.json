{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Consensus Panel Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "understood_question",
    "response",
    "key_points",
    "risks",
    "assumptions",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "understood_question": {
      "type": "string"
    },
    "response": {
      "type": "string"
    },
    "key_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  }
}
