{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "consensus-plugin/v0/verdict-alternating.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verdict", "reasoning"],
  "properties": {
    "schema_version": { "const": "v0" },
    "verdict": { "enum": ["ACCEPT", "REVISE", "IMPASSE"] },
    "reasoning": { "type": "string" },
    "proposed_artifact": { "type": "string" },
    "concerns": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "oneOf": [
    {
      "properties": { "verdict": { "const": "ACCEPT" } },
      "not": { "required": ["proposed_artifact"] }
    },
    {
      "properties": { "verdict": { "const": "REVISE" } },
      "required": ["proposed_artifact"]
    },
    {
      "properties": { "verdict": { "const": "IMPASSE" } },
      "not": { "required": ["proposed_artifact"] }
    }
  ]
}
