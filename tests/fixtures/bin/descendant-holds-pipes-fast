#!/usr/bin/env bash
# Regression fixture for the "descendant holds the stdio pipes open" hang
# class, built as a shell script (not a Node script) so it reaches its
# `trap '' TERM` line before a short deadline can race its own startup — see
# ignore-sigterm-fast for the same reasoning.
#
# Backgrounds a detached `sleep` that inherits this script's stdout/stderr
# (the pipes the test runner reads from) and outlives it, then ignores
# SIGTERM itself so only SIGKILL can end this process. Even after SIGKILL,
# the backgrounded descendant keeps the pipes' write ends open, so a runner
# that waits exclusively on the child_process 'close' event hangs forever
# unless it has a final-resolution safety net.
#
# The descendant's own sleep is intentionally short (well past the runner's
# deadline+grace+final-resolution window, but not indefinite): nothing in
# this process tree is reaped by the test harness once detached, so a long
# duration here would otherwise leak a real OS process for that long on every
# test run.
set -eu
# Background the pipe-holding descendant FIRST, before installing the trap,
# so it is already detached and holding the pipes open even in the (rare,
# cold-start) case where SIGTERM arrives before `trap` executes.
(sleep 10 &)
trap '' TERM
exec sleep 86400
