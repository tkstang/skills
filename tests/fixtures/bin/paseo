#!/usr/bin/env node
import fs from 'node:fs';
import { once } from 'node:events';
import path from 'node:path';

function writeCapture() {
  if (!process.env.PASEO_STUB_CAPTURE_PATH) return;

  fs.mkdirSync(path.dirname(process.env.PASEO_STUB_CAPTURE_PATH), { recursive: true });
  fs.writeFileSync(
    process.env.PASEO_STUB_CAPTURE_PATH,
    `${JSON.stringify(
      {
        argv: process.argv.slice(2),
        cwd: process.cwd()
      },
      null,
      2
    )}\n`
  );
}

function responsePayload() {
  if (process.env.PASEO_STUB_RESPONSE_FILE) {
    return fs.readFileSync(process.env.PASEO_STUB_RESPONSE_FILE, 'utf8');
  }

  if (process.env.PASEO_STUB_RESPONSE_JSON) {
    return process.env.PASEO_STUB_RESPONSE_JSON;
  }

  return JSON.stringify({
    schema_version: 'v1',
    verdict: 'ACCEPT',
    reasoning: 'fixture accepted'
  });
}

async function writeRepeated(stream, character, bytes) {
  const chunk = character.repeat(Math.min(bytes, 64 * 1024));
  let remaining = bytes;

  while (remaining > 0) {
    const next = remaining >= chunk.length ? chunk : character.repeat(remaining);
    remaining -= next.length;
    if (!stream.write(next)) {
      await once(stream, 'drain');
    }
  }
}

writeCapture();

if (process.env.PASEO_STUB_STDERR) {
  process.stderr.write(process.env.PASEO_STUB_STDERR);
}

if (process.env.PASEO_STUB_STDERR_BYTES) {
  await writeRepeated(process.stderr, 'e', Number(process.env.PASEO_STUB_STDERR_BYTES));
}

const exitCode = Number(process.env.PASEO_STUB_EXIT_CODE ?? 0);
if (exitCode !== 0) {
  process.exit(exitCode);
}

if (process.env.PASEO_STUB_STDOUT_BYTES) {
  await writeRepeated(process.stdout, 'x', Number(process.env.PASEO_STUB_STDOUT_BYTES));
  process.exit(0);
}

if (process.env.PASEO_STUB_JSON_WITH_PADDING_BYTES) {
  process.stdout.write(responsePayload());
  process.stdout.write(' '.repeat(Number(process.env.PASEO_STUB_JSON_WITH_PADDING_BYTES)));
  process.exit(0);
}

process.stdout.write(responsePayload());
