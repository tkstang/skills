{
  "schemaVersion": "explainer-kit.recipe/v1",
  "id": "program-recap",
  "version": "1",
  "sourceRoles": [
    {
      "role": "program",
      "required": true,
      "accepts": ["file", "directory", "git"],
      "minBindings": 1,
      "maxBindings": 1
    }
  ],
  "requiredNarrative": [
    "program-overview",
    "wave-map",
    "per-wave-outcomes",
    "convention-evolution",
    "aggregate-numbers",
    "follow-up-ledger"
  ],
  "artifacts": [
    {
      "id": "program-recap",
      "type": "hub",
      "template": "house-style",
      "required": true
    }
  ],
  "discoveryLimits": {
    "consecutiveNoNewFindingsRounds": 2,
    "maxRounds": 8
  }
}
