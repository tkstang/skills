# OAT core
.oat/config.local.json
.oat/state.md
.oat/projects/local/**
.oat/projects/archived/**
!.oat/projects/local/.gitkeep
!.oat/projects/archived/.gitkeep
# END OAT core

# OAT local paths
.oat/projects/**/pr/
.oat/projects/**/reviews/archived/
# END OAT local paths

# OAT analysis artifacts (machine-local provenance; content is captured in PRs)
.oat/repo/analysis/
# END OAT analysis artifacts

.superpowers/

# Node/runtime outputs
node_modules/
.consensus/
tmp/
temp/
*.tmp
# Consensus wrapper writes <input>.consensus.md beside its input; keep test-run
# and operator-QA output leaks out of git.
tests/fixtures/*.consensus.md
plugins/consensus/skills/refine/references/examples/*.consensus.md
# END Node/runtime outputs